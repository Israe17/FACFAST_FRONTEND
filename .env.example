BACKEND_URL=http://localhost:3002

# Public URL the browser uses to open the realtime WebSocket. In dev this
# is the backend itself (Next.js cannot proxy WS upgrades via rewrites).
# In production point it at whatever the browser can reach the backend
# at (often the same origin if you reverse-proxy /socket.io behind your
# edge). Leave empty to default to window.location.origin.
NEXT_PUBLIC_REALTIME_URL=http://localhost:3002
